# Copiar a .env antes de npm run build (producción) o npm run dev (local).

# — API (Vite inyecta esto en el build) —
# Desarrollo: déjalo vacío o comentado. Las peticiones van a /api/... y Vite las proxifica a 127.0.0.1:3001 (vite.config.js).
# Producción (frontend en un host distinto al API): URL pública del backend, SIN barra final.
# Ejemplo Google Cloud: VITE_API_URL=http://TU_IP_PUBLICA:3001
# Si sirves /api desde el mismo dominio (nginx, etc.), puedes dejarlo vacío.
# VITE_API_URL=

# — Caché de assets en public/assets —
# Sube el número cuando reemplaces vídeos/imágenes con la misma ruta para forzar recarga en clientes.
# VITE_ASSET_VERSION=1
